<!DOCTYPE html>
<html>
<head>
    <title>Edit User</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-warning">
                    <h3 class="mb-0">Edit User</h3>
                </div>
                <div class="card-body">
                    <form action="/edit/<%= user.id %>" method="POST" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label class="form-label">Name:</label>
                            <!-- Minimal Improvement: Form validation and better form layout -->
                            <input type="text" name="name" value="<%= user.name %>" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email:</label>
                            <input type="email" name="email" value="<%= user.email %>" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Current Image:</label><br>
                            <% if (user.filepath) { %>
                                <img src="/<%= user.filepath %>" class="img-thumbnail mb-2" style="max-height: 150px;">
                            <% } else { %>
                                <span class="text-muted d-block mb-2">No existing image</span>
                            <% } %>
                            
                            <label class="form-label">New Image (Optional):</label>
                            <input type="file" name="file" class="form-control" accept="image/*">
                            <small class="text-muted">Leave empty to keep the current image.</small>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary flex-grow-1">Update User</button>
                            <a href="/" class="btn btn-secondary flex-grow-1">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
