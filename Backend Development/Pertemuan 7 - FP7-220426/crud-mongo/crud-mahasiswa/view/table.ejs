<!-- DataTales Example -->
<div class="card shadow mb-4">
  <div class="card-header py-3">
    <!-- Button trigger modal -->
    <button
      type="button"
      class="btn btn-outline-primary btn-sm"
      data-toggle="modal"
      data-target="#add-modal"
    >
      Add
    </button>
  </div>
  <div class="card-body">
    <div class="table-responsive">
      <table
        class="table table-bordered"
        id="dataTable"
        width="100%"
        cellspacing="0"
      >
        <thead>
          <tr>
            <th>No</th>
            <th>Nama</th>
            <th>NIM</th>
            <th>Jurusan</th>
            <th>Alamat</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% for (let i = 0; i < mahasiswa.length; i++) { %>
          <tr>
            <td><%= i + 1 %></td>
            <td><%= mahasiswa[i].Nama %></td>
            <td><%= mahasiswa[i].Nim %></td>
            <td><%= mahasiswa[i].Jurusan %></td>
            <td><%= mahasiswa[i].Alamat %></td>
            <td class="text-center">
              <a href="/mahasiswa/edit/<%= mahasiswa[i]._id %>" class="btn btn-outline-warning btn-sm">Edit</a>
              <form action="/mahasiswa/delete/<%= mahasiswa[i]._id %>" method="POST" style="display:inline;">
                <input type="hidden" name="_method" value="DELETE">
                <button type="submit" class="btn btn-outline-danger btn-sm">
                  Delete
                </button>
              </form>
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
